# Application identity used by FastAPI and log filenames.
NAME_APP=Formy02

# Runtime mode: development, testing, or production.
RUN_ENVIRONMENT=development

# Secret key for JWTs and signed session cookies.
SECRET_KEY=

# Public base URL used in verification and password reset email links.
URL_BASE_WEBSITE=http://localhost:8000

# Comma-separated whitelist of admin email addresses allowed to register.
EMAIL_ADMIN_USER=

# Directory for app-managed resources such as database backups and external images.
PATH_PROJECT_RESOURCES=/home/limited_user/project_resources/Formy02

# Directory where uploaded questionnaire audio files are stored.
AUDIO_FILES_PATH=/home/limited_user/project_resources/Formy02/audio

# Filename for Nick's externally stored hero/hello photo.
# Store it at: ${PATH_PROJECT_RESOURCES}/images/${HERO_IMAGE_FILENAME}
HERO_IMAGE_FILENAME=hello_picture.jpg

# PostgreSQL host name or IP. Use loopback to match local trust auth.
DB_HOST=127.0.0.1

# PostgreSQL port.
DB_PORT=5432

# PostgreSQL database name.
DB_NAME=formy02

# PostgreSQL user.
DB_USER=formy02

# Optional PostgreSQL schema name.
DB_SCHEMA=

# Gmail SMTP username for verification/reset email.
GMAIL_SMTP_USER=

# Gmail SMTP app password.
GMAIL_SMTP_APP_PASSWORD=

# SMTP host.
GMAIL_SMTP_HOST=smtp.gmail.com

# SMTP port.
GMAIL_SMTP_PORT=587

# Log directory, required for testing and production.
PATH_TO_LOGS=./logs

# Maximum log file size before rotation, in megabytes.
LOG_MAX_SIZE_IN_MB=5

# Maximum retained log files.
LOG_MAX_FILES=5
